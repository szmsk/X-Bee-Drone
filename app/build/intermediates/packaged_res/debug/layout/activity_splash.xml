<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/drone_bg">

    <!-- Logo i nazwa -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_drone_logo"
        app:layout_constraintBottom_toTopOf="@id/tvAppName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="X-BEE DRONE"
        android:textColor="@color/drone_accent"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        app:layout_constraintBottom_toTopOf="@id/tvAppSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivLogo" />

    <TextView
        android:id="@+id/tvAppSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="9.5 FOLD CONTROLLER"
        android:textColor="#80FFFFFF"
        android:textSize="14sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toTopOf="@id/tvWifiCurrent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppName" />

    <!-- WiFi info -->
    <TextView
        android:id="@+id/tvWifiLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📶 Połączenie WiFi drona"
        android:textColor="#AAFFFFFF"
        android:textSize="13sp"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/tvWifiCurrent"
        app:layout_constraintStart_toStartOf="@id/etWifiSsid"
        app:layout_constraintTop_toBottomOf="@id/tvAppSubtitle" />

    <TextView
        android:id="@+id/tvWifiCurrent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Połączony z: —"
        android:textColor="@color/drone_accent"
        android:textSize="13sp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/etWifiSsid"
        app:layout_constraintEnd_toEndOf="@id/etWifiSsid"
        app:layout_constraintStart_toStartOf="@id/etWifiSsid"
        app:layout_constraintTop_toBottomOf="@id/tvWifiLabel" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilWifiSsid"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:hint="SSID drona (np. XBEE_9.5)"
        app:boxStrokeColor="@color/drone_accent"
        app:hintTextColor="@color/drone_accent"
        app:layout_constraintBottom_toTopOf="@id/progressBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvWifiCurrent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etWifiSsid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tilWifiSsid"
        app:layout_constraintBottom_toTopOf="@id/tvStatus" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gotowy do połączenia"
        android:textColor="#AAFFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintBottom_toTopOf="@id/btnConnect" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConnect"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="🔌 POŁĄCZ Z DRONEM"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:backgroundTint="@color/drone_accent"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toTopOf="@id/btnSkip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSkip"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pomiń (tryb offline)"
        android:textColor="#80FFFFFF"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="40dp"
        app:strokeColor="#40FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnConnect" />

</androidx.constraintlayout.widget.ConstraintLayout>
