<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Nagłówek i status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 TELEMETRIA"
                android:textColor="#FF5722"
                android:textSize="18sp"
                android:textStyle="bold" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/tvConnectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❌ Brak połączenia"
                android:textColor="#F44336"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Czas lotu -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ CZAS LOTU"
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvFlightTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#FF5722"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/btnResetTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="RESET"
                    android:textSize="10sp"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- BATERIA -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔋 BATERIA DRONA"
                        android:textColor="#888888"
                        android:textSize="12sp" />

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvBatteryValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--%"
                        android:textColor="#43A047"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/batteryBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#43A047"
                    android:progressBackgroundTint="#333333" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- WYSOKOŚĆ i PRĘDKOŚĆ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Wysokość -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="8dp"
                android:layout_marginEnd="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↕ WYSOKOŚĆ"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvAltValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 m"
                        android:textColor="#2196F3"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Prędkość -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="8dp"
                android:layout_marginStart="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ PRĘDKOŚĆ"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvSpeedValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 km/h"
                        android:textColor="#FF9800"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <ProgressBar
                        android:id="@+id/speedBar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="40"
                        android:progress="0"
                        android:progressTint="#FF9800"
                        android:progressBackgroundTint="#333333"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- GPS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛰 GPS"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <!-- Szerokość -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                        android:text="Szerokość (LAT)" android:textColor="#666666" android:textSize="12sp" />
                    <TextView android:id="@+id/tvLatValue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.000000°"
                        android:textColor="#FFFFFF" android:textSize="14sp" android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Długość -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                        android:text="Długość (LON)" android:textColor="#666666" android:textSize="12sp" />
                    <TextView android:id="@+id/tvLonValue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.000000°"
                        android:textColor="#FFFFFF" android:textSize="14sp" android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Satelity -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                        android:text="Satelity" android:textColor="#666666" android:textSize="12sp" />
                    <TextView android:id="@+id/tvSatValue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="#43A047" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Dystans od Home -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                        android:text="Dystans (Home)" android:textColor="#666666" android:textSize="12sp" />
                    <TextView android:id="@+id/tvDistValue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="-- m"
                        android:textColor="#FFFFFF" android:textSize="14sp" android:fontFamily="monospace" />
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- SYGNAŁ WiFi -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📶 SYGNAŁ WiFi 5GHz"
                        android:textColor="#888888"
                        android:textSize="12sp" />

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvSignalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--%"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/signalBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#2196F3"
                    android:progressBackgroundTint="#333333" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Przyciski akcji -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnSetHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📍 Ustaw HOME"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnResetTimer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏱ Reset czasu"
                android:textColor="#FFFFFF"
                android:backgroundTint="#424242" />

        </LinearLayout>

        <!-- Info o dronie -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#111111"
            app:cardCornerRadius="8dp"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ Overmax X-Bee Drone 9.5 Fold"
                    android:textColor="#555555"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Max zasięg: 600m | Max prędkość: 40km/h | Max czas lotu: 22min | Klasa C0"
                    android:textColor="#444444"
                    android:textSize="10sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
