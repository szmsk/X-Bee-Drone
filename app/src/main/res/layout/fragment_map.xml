<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Górny pasek -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvWaypointCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waypoints: 0"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tvWaypointHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👆 Dotknij mapę aby dodać waypoint"
            android:textColor="#FF5722"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Przyciski boczne -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/topPanel"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnCenterDrone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Dron"
            app:srcCompat="@drawable/ic_fpv"
            app:backgroundTint="#FF5722"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnCenterMe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Moja pozycja"
            app:srcCompat="@drawable/ic_map"
            app:backgroundTint="#1565C0"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnAddWaypoint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Dodaj waypoint"
            app:srcCompat="@drawable/ic_telemetry"
            app:backgroundTint="#43A047"
            android:alpha="0.5"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnClearWaypoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Wyczyść waypoints"
            app:srcCompat="@drawable/ic_telemetry"
            app:backgroundTint="#757575"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnClearTrack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Wyczyść ślad"
            app:srcCompat="@drawable/ic_telemetry"
            app:backgroundTint="#424242" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
