<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Podgląd kamery FPV -->
    <ImageView
        android:id="@+id/videoView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        android:background="#111111"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Krzyżyk celownika -->
    <View
        android:layout_width="50dp"
        android:layout_height="1dp"
        android:background="#60FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:layout_width="1dp"
        android:layout_height="50dp"
        android:background="#60FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- HUD górny pasek -->
    <LinearLayout
        android:id="@+id/hudTop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#BB000000"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_red"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rozłączony"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tvBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔋 --%"
            android:textColor="#43A047"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvAltitude"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↕ 0.0m"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ 0.0km/h"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvSatellites"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛰 0"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvSignal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📶 --%"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Prawy górny: tryby lotu -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/hudTop"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnHeadless"
            android:layout_width="88dp"
            android:layout_height="36dp"
            android:text="HEADLESS"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6A1B9A"
            android:alpha="0.45"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnAltHold"
            android:layout_width="88dp"
            android:layout_height="36dp"
            android:text="ALT HOLD"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00695C"
            android:alpha="1.0" />

    </LinearLayout>

    <!-- Lewy joystick: Gaz + Obrót -->
    <com.xbeedrone.app.ui.JoystickView
        android:id="@+id/joystickLeft"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Prawy joystick: Pitch + Roll -->
    <com.xbeedrone.app.ui.JoystickView
        android:id="@+id/joystickRight"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Przyciski środkowe -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnTakeoffLand"
                android:layout_width="88dp"
                android:layout_height="44dp"
                android:text="START"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#43A047"
                android:layout_marginHorizontal="4dp"
                android:enabled="false" />

            <Button
                android:id="@+id/btnRth"
                android:layout_width="72dp"
                android:layout_height="44dp"
                android:text="🏠 RTH"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0"
                android:layout_marginHorizontal="4dp"
                android:enabled="false" />

            <Button
                android:id="@+id/btnEmergency"
                android:layout_width="72dp"
                android:layout_height="44dp"
                android:text="⚠ STOP"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B71C1C"
                android:layout_marginHorizontal="4dp"
                android:enabled="false" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="88dp"
                android:layout_height="38dp"
                android:text="POŁĄCZ"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0"
                android:layout_marginHorizontal="4dp" />

            <Button
                android:id="@+id/btnPhoto"
                android:layout_width="56dp"
                android:layout_height="38dp"
                android:text="📷"
                android:textSize="16sp"
                android:backgroundTint="#424242"
                android:layout_marginHorizontal="4dp"
                android:enabled="false" />

            <Button
                android:id="@+id/btnRecord"
                android:layout_width="88dp"
                android:layout_height="38dp"
                android:text="⏺ REC"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#757575"
                android:layout_marginHorizontal="4dp"
                android:enabled="false" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
