<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Główny motyw aplikacji — ciemny, bez ActionBar -->
    <style name="Theme.XBeeDrone" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#FF5722</item>
        <item name="colorPrimaryVariant">#E64A19</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FF5722</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:colorBackground">#0A0A0A</item>
        <item name="colorSurface">#1A1A1A</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:statusBarColor">#0A0A0A</item>
        <item name="android:navigationBarColor">#0A0A0A</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Alias dla zgodności (manifest może odwoływać się do obu nazw) -->
    <style name="Theme.XBeeDrone.NoActionBar" parent="Theme.XBeeDrone" />

    <!-- Styl dialogów -->
    <style name="DroneAlertDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">#FF5722</item>
        <item name="android:colorBackground">#1A1A1A</item>
        <item name="colorOnSurface">#FFFFFF</item>
    </style>

</resources>
